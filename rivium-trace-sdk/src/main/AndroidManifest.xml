<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for sending error reports -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Optional: For offline error caching -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application>
        <!-- Provider for initializing SDK automatically -->
        <provider
            android:name="co.rivium.trace.sdk.RiviumTraceInitProvider"
            android:authorities="${applicationId}.rivium-trace-init"
            android:exported="false"
            android:initOrder="100" />

        <!-- Service for ANR detection -->
        <service
            android:name="co.rivium.trace.sdk.services.ANRWatchdogService"
            android:exported="false" />
    </application>

</manifest>
